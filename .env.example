# SmolLM2-1.7B Mobile Kit — Environment Configuration

# Base model to fine-tune
BASE_MODEL=HuggingFaceTB/SmolLM2-1.7B-Instruct

# Dataset for fine-tuning
DATASET_NAME=tatsu-lab/alpaca

# Number of samples to use for training (set to 1000 for full demo)
NUM_SAMPLES=1000

# LoRA configuration
LORA_R=8
LORA_ALPHA=16
LORA_DROPOUT=0.05

# Training configuration
NUM_EPOCHS=3
BATCH_SIZE=4
LEARNING_RATE=2e-4
MAX_SEQ_LEN=512

# Output directories
ADAPTER_OUTPUT_DIR=models/smollm2-lora-adapter
MERGED_MODEL_DIR=models/smollm2-merged
GGUF_OUTPUT_DIR=models/gguf

# Benchmark configuration
BENCHMARK_REPORT=benchmark_report.md
BENCHMARK_RESULTS=outputs/benchmark_results.json
MMLU_SUBJECTS=high_school_mathematics,college_computer_science,world_history,high_school_physics,professional_medicine
MMLU_QUESTIONS_PER_SUBJECT=50
MMLU_FEWSHOT=5
PPL_NUM_SAMPLES=50
SPEED_TEST_TOKENS=100

# Demo mode (0 = real, 1 = mock)
DEMO_MOCK_MODE=1

# HuggingFace token (optional, for private models)
# HUGGINGFACE_TOKEN=your_token_here
